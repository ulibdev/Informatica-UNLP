programa p3ej2
procesos
  proceso asignarids
  comenzar
    EnviarMensaje(1,r1)
    EnviarMensaje(2,r2)
    EnviarMensaje(3,r3)
    EnviarMensaje(4,r4)
  fin
  proceso enviarEsquina(E x:numero;E y:numero)
  comenzar
    EnviarMensaje(x,r1)
    EnviarMensaje(x,r2)
    EnviarMensaje(x,r3)
    EnviarMensaje(x,r4)
    EnviarMensaje(y,r1)
    EnviarMensaje(y,r2)
    EnviarMensaje(y,r3)
    EnviarMensaje(y,r4)
  fin
  proceso agarrarFlor(E x:numero;E y:numero;ES f:numero)
  variables
    pav:numero
    pca:numero
  comenzar
    pav:=PosAv
    pca:=PosCa
    BloquearEsquina(x,y)
    Pos(x,y)
    mientras(HayFlorEnLaEsquina)
      tomarFlor
      f:=f+1
      Pos(pav,pca)
      LiberarEsquina(x,y)
      BloquearEsquina(x,y)
      Pos(x,y)
    Pos(pav,pca)
    LiberarEsquina(x,y)
  fin
  proceso informarMax
  variables
    max:numero
    idmax:numero
    idnuevo:numero
    nuevo:numero
  comenzar
    max:=-1
    repetir 4
      RecibirMensaje(idnuevo,*)
      si(idnuevo = 1)
        RecibirMensaje(nuevo,r1)
      sino
        si(idnuevo = 2)
          RecibirMensaje(nuevo,r2)
        sino
          si(idnuevo = 3)
            RecibirMensaje(nuevo,r3)
          sino
            RecibirMensaje(nuevo,r4)
      si(max<nuevo)
        max:=nuevo
        idmax:=idnuevo
    Informar("el Robot tiene el max de flores es ",idmax)
  fin
areas
  area1:AreaP(1,1,1,1)
  area2:AreaP(2,1,2,1)
  area3:AreaP(3,1,3,1)
  area4:AreaP(4,1,4,1)
  area5:AreaP(5,1,5,1)
  area:AreaPC(2,2,10,10)
robots
  robot juntador
  variables
    f:numero
    x:numero
    y:numero
    id:numero
  comenzar
    RecibirMensaje(id,rjefe)
    RecibirMensaje(x,rjefe)
    RecibirMensaje(y,rjefe)
    f:=0
    agarrarFlor(x,y,f)
    EnviarMensaje(id,rjefe)
    EnviarMensaje(f,rjefe)
  fin
  robot jefazo
  variables
    x:numero
    y:numero
  comenzar
    asignarids
    Random(x,2,10)
    Random(y,2,10)
    enviarEsquina(x,y)
    informarMax
  fin
variables
  r1:juntador
  r2:juntador
  r3:juntador
  r4:juntador
  rjefe:jefazo
comenzar
  AsignarArea(r1,area)
  AsignarArea(r2,area)
  AsignarArea(r3,area)
  AsignarArea(r4,area)
  AsignarArea(r1,area2)
  AsignarArea(r2,area3)
  AsignarArea(r3,area4)
  AsignarArea(r4,area5)
  AsignarArea(rjefe,area1)
  Iniciar(r1,2,1)
  Iniciar(r2,3,1)
  Iniciar(r3,4,1)
  Iniciar(r4,5,1)
  Iniciar(rjefe,1,1)
fin