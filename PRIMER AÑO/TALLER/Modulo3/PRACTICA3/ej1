programa p3ej1
procesos
  proceso juntarFlores(ES f:numero)
  comenzar
    mientras(HayFlorEnLaEsquina)
      tomarFlor
      f:=f+1
  fin
  proceso juntarPapeles(ES p:numero)
  comenzar
    mientras(HayPapelEnLaEsquina)
      tomarPapel
      p:=p+1
  fin
  proceso entrarZonaP(ES p:numero)
  variables
    avIni:numero
    caIni:numero
    avRan:numero
    caRan:numero
  comenzar
    avIni:=PosAv
    caIni:=PosCa
    repetir 3
      Random(avRan,6,10)
      Random(caRan,1,9)
      BloquearEsquina(avRan,caRan)
      Pos(avRan,caRan)
      juntarPapeles(p)
      Pos(avIni,caIni)
      LiberarEsquina(avRan,caRan)
  fin
  proceso entrarZonaF(ES f:numero)
  variables
    avIni:numero
    caIni:numero
    avRan:numero
    caRan:numero
  comenzar
    avIni:=PosAv
    caIni:=PosCa
    repetir 5
      Random(avRan,1,5)
      Random(caRan,1,10)
      BloquearEsquina(avRan,caRan)
      Pos(avRan,caRan)
      juntarFlores(f)
      Pos(avIni,caIni)
      LiberarEsquina(avRan,caRan)
  fin
  proceso dejarFlores(E f:numero)
  variables
    avIni:numero
    caIni:numero
  comenzar
    avIni:= PosAv
    caIni:= PosCa
    repetir f
      BloquearEsquina(10,10)
      Pos(10,10)
      depositarFlor
      Pos(avIni,caIni)
      LiberarEsquina(10,10)
  fin
  proceso dejarPapeles(E p:numero)
  variables
    avIni:numero
    caIni:numero
  comenzar
    avIni:= PosAv
    caIni:= PosCa
    repetir p
      BloquearEsquina(10,10)
      Pos(10,10)
      depositarPapel
      Pos(avIni,caIni)
      LiberarEsquina(10,10)
  fin
areas
  areaf:AreaPC(1,1,5,10)
  areap:AreaPC(6,1,10,9)
  area1:AreaP(6,10,6,10)
  area2:AreaP(7,10,7,10)
  area3:AreaP(8,10,8,10)
  area4:AreaP(9,10,9,10)
  areaCom:AreaC(10,10,10,10)
robots
  robot juntadorP
  variables
    papeles:numero
  comenzar
    papeles:=0
    entrarZonaP(papeles)
    dejarPapeles(papeles)
  fin
  robot juntadorF
  variables
    flores:numero
  comenzar
    flores:=0
    entrarZonaF(flores)
    dejarFlores(flores)
  fin
variables
  r1:juntadorF
  r2:juntadorF
  r3:juntadorP
  r4:juntadorP
comenzar
  AsignarArea(r1,area1)
  AsignarArea(r2,area2)
  AsignarArea(r3,area3)
  AsignarArea(r4,area4)
  AsignarArea(r1,areaf)
  AsignarArea(r2,areaf)
  AsignarArea(r3,areap)
  AsignarArea(r4,areap)
  AsignarArea(r1,areaCom)
  AsignarArea(r2,areaCom)
  AsignarArea(r3,areaCom)
  AsignarArea(r4,areaCom)
  Iniciar(r1,6,10)
  Iniciar(r2,7,10)
  Iniciar(r3,8,10)
  Iniciar(r4,9,10)
fin