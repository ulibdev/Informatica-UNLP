programa ej2
procesos
  proceso juntarPapeles(ES p:numero)
  comenzar
    si(HayPapelEnLaEsquina)
      mientras(HayPapelEnLaEsquina) &( p<5)
        tomarPapel
        p:=p+1
    sino
      mover
  fin
  proceso dejarPapel(ES p:numero)
  variables
    av:numero
    ca:numero
  comenzar
    av:=PosAv
    ca:=PosCa
    BloquearEsquina(50,50)
    Pos(50,50)
    repetir p
      depositarPapel
    Pos(av,ca)
    LiberarEsquina(50,50)
    p:=0
  fin
  proceso consumir(ES papel:numero; ES intentos:numero)
  variables
    av:numero
    ca:numero
    papelAgarrados:numero
  comenzar
    av:=PosAv
    ca:=PosCa
    papelAgarrados:=0
    BloquearEsquina(50,50)
    Pos(50,50)
    mientras(HayPapelEnLaEsquina) &(papelAgarrados < papel)
      tomarPapel
      papelAgarrados:=papelAgarrados + 1
    si(papel = papelAgarrados)
      intentos:= 8
    sino
      papel:=0
      intentos:=intentos-1
      repetir papelAgarrados
        depositarPapel
    Pos(av,ca)
    LiberarEsquina(50,50)
  fin
  proceso dejarPapeles(E p:numero)
  comenzar
    repetir p
      depositarPapel
  fin
areas
  area1:AreaP(5,1,5,100)
  area2:AreaP(10,1,10,100)
  area3:AreaP(11,1,11,1)
  area4:AreaP(12,1,12,1)
  areaCOM:AreaC(50,50,50,50)
robots
  robot recolector
  variables
    papel:numero
  comenzar
    papel:=0
    mientras(PosCa<100)
      si(papel<5)
        juntarPapeles(papel)
      sino
        dejarPapel(papel)
  fin
  robot consumidor
  variables
    papel,intentos:numero
  comenzar
    intentos:=8
    mientras(intentos>0)
      Random(papel,2,5)
      consumir(papel,intentos)
      dejarPapeles(papel)
  fin
variables
  r1:recolector
  r2:recolector
  r3:consumidor
  r4:consumidor
comenzar
  AsignarArea(r1,area1)
  AsignarArea(r1,areaCOM)
  AsignarArea(r2,areaCOM)
  AsignarArea(r2,area2)
  AsignarArea(r3,areaCOM)
  AsignarArea(r3,area3)
  AsignarArea(r4,areaCOM)
  AsignarArea(r4,area4)
  Iniciar(r1,5,1)
  Iniciar(r2,10,1)
  Iniciar(r3,11,1)
  Iniciar(r4,12,1)
fin
