
programa ejercicio3
procesos
  proceso juntarPapeles
  comenzar
    mientras HayPapelEnLaEsquina
      tomarPapel
  fin
  proceso asignarId
  comenzar
    EnviarMensaje(1,R1)
    EnviarMensaje(2,R2)
    EnviarMensaje(3,R3)
  fin
  proceso moverse
  variables
    movidas:numero
  comenzar
    movidas:=0
    mientras(PosCa<100) &(movidas < 5)
      juntarPapeles
      mover
      movidas:=movidas+1    
  fin
  proceso termine(E id:numero)
  comenzar
    si(id = 1)
      EnviarMensaje(V,R2)
      EnviarMensaje(V,R3)
    sino
      si(id = 2)
        EnviarMensaje(V,R1)
        EnviarMensaje(V,R3)
      sino
        EnviarMensaje(V,R1)
        EnviarMensaje(V,R2)
  fin
  proceso esperar
  variables
    b:boolean
  comenzar
    repetir 2
      RecibirMensaje(b,*)
  fin
areas
  area1: AreaP (1,1,1,100)
  area2: AreaP (2,1,2,100)
  area3: AreaP (3,1,3,100)
  oficina: AreaP (100,100,100,100)
robots
  robot robot1
  variables
    id:numero
  comenzar
    RecibirMensaje(id,coordinador)
    mientras(PosCa<100)
      moverse
      termine(id)
      esperar
    juntarPapeles
  fin
  robot fiscalizador
  comenzar
    asignarId
  fin
variables
  R1,R2,R3: robot1
  coordinador: fiscalizador
comenzar
  AsignarArea(R1, area1)
  AsignarArea(R2, area2)
  AsignarArea(R3, area3)
  AsignarArea(coordinador, oficina)
  Iniciar(coordinador, 100,100)
  Iniciar(R1, 1,1)
  Iniciar(R2, 2,1)
  Iniciar(R3, 3,1)
fin